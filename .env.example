APP_NAME="ADM - Coworking"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://adm.chatboot.cloud

# Mesma URL pública do app (SPA + redirect Google OAuth).
FRONTEND_URL=https://adm.chatboot.cloud

# HTTPS: redireciona HTTP→HTTPS e envia cabeçalhos HSTS (cadeado verde no navegador).
FORCE_HTTPS=true
SESSION_SECURE_COOKIE=true

# E-mail que recebe papel admin automaticamente no cadastro/login Google.
ADMIN_EMAIL=admin@example.com

APP_LOCALE=pt
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Coolify: crie um serviço MySQL ou PostgreSQL e use o host interno do Coolify.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=coworking_uemasul
DB_USERNAME=coworking
# Senha com caracteres especiais (@, #, etc.): no Coolify use aspas, ex.: DB_PASSWORD="suaSenha@123"
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Horário de reservas (faixas de 1h entre início e término)
COWORKING_START_HOUR=14
COWORKING_END_HOUR=22

VITE_APP_NAME="${APP_NAME}"
# Em dev com `npm run dev`, deixe vazio para usar o proxy do Vite (vite.config.js).
VITE_API_URL=

SANCTUM_STATEFUL_DOMAINS=adm.chatboot.cloud,localhost,127.0.0.1

# Google OAuth — https://console.cloud.google.com/apis/credentials
# 1) Tipo "Aplicativo da Web"
# 2) URI de redirecionamento = {mesmo protocolo do domínio}/auth/google/callback
#    Ex. Coolify sslip (http): http://SEU-DOMINIO.sslip.io/auth/google/callback
#    Ex. produção (https): https://adm.chatboot.cloud/auth/google/callback
# 3) Deixe GOOGLE_REDIRECT_URI vazio — o app monta a URL automaticamente pelo domínio acessado
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Origens permitidas pelo CORS (separadas por vírgula).
CORS_ALLOWED_ORIGINS=https://adm.chatboot.cloud

# Regras de reserva (horas mínimas antes do início para cancelar)
COWORKING_CANCEL_HOURS_BEFORE=3
# Edição: use segundos (prioridade) ou minutos. Para testes: 30 segundos.
COWORKING_EDIT_WINDOW_SECONDS=30
# COWORKING_EDIT_WINDOW_MINUTES=10
